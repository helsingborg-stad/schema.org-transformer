SCRIPTS_HOME=/opt/schema-transformer/scripts
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Schema Transformer: Helsingborg Reachmee: At every 2nd minute from 1 through 59.
1-59/2 * * * * root /bin/bash /opt/schema-transformer/.docker/run-cron-job.sh reachmee-helsingborg-se $SCRIPTS_HOME/reachmee/helsingborg.se/run.sh

# Schema Transformer: Helsingborg Innovation Stratsys: Every 5 minutes
*/5 * * * * root /bin/bash /opt/schema-transformer/.docker/run-cron-job.sh stratsys-innovation $SCRIPTS_HOME/stratsys/innovation.helsingborg.se/run.sh

